# Online model calls. Required for map-rdtii cache misses and final-audit live mode.
OPENAI_API_KEY=

# Optional model overrides. Leave blank for project defaults.
RDTII_MAPPER_MODEL=
RDTII_REVIEW_MODEL=
RDTII_PDF_MAPPER_MODEL=

# Final auditor. Defaults to cache_only when unset.
RDTII_FINAL_AUDIT_MODE=cache_only

# Docling materialization mode. Defaults to cpu when unset.
RDTII_DOCLING_MODE=cpu
RDTII_DOCLING_MAX_PAGES=500

