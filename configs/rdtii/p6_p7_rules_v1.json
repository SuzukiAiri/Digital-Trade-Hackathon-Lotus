  "indicators": [
    {"indicator_id":"P6-I1","title":"Ban and local processing requirements","task_type":"provision_classification","core_question":"Does a binding rule prohibit cross-border transfer or require domestic processing without an ordinary compliance path?","source_scope":["binding current legal text"],"positive_conditions":["cross-border transfer ban","foreign processing ban","mandatory domestic processing"],"required_signals":["transfer_or_processing","prohibition_or_mandate","domestic_nexus","ordinary_compliance_path_exists"],"exclusion_conditions":["consent, adequacy, safeguards, approval or another ordinary lawful path","confidentiality or unauthorised disclosure","security or access control"],"confusable_with":["P6-I4","P6-I2","P6-I3"],"query_groups":{"objects":["personal data","data","information"],"actions":["transfer","process","disclose"],"location_or_authority":["outside Singapore","foreign","Singapore","domestic"],"legal_modality":["must not","shall not","must","required"],"exact_phrases":["must be processed in Singapore","shall not transfer outside Singapore"]},"rule_filter":{"pass_when":["all required signals and ordinary_compliance_path_exists is false"],"reject_when":["ordinary_compliance_path_exists is true"],"review_when":["scope or path is unclear"]},"output_fields":["ordinary_compliance_path_exists","conditions","exceptions"]},
    {"indicator_id":"P6-I2","title":"Local storage requirements","task_type":"provision_classification","core_question":"Does a binding rule require data or records to be stored domestically while transfer remains possible?","source_scope":["binding current legal text"],"positive_conditions":["domestic storage of data, records, database or copy"],"required_signals":["storage_signal","domestic_location_signal"],"exclusion_conditions":["retention duration only","authority access only","local server/data centre","complete outbound ban"],"confusable_with":["P6-I1","P6-I3","P7-I3"],"query_groups":{"objects":["data","records","database","information","copy"],"actions":["store","keep","retain","maintain","preserve"],"location_or_authority":["Singapore","within Singapore","locally","domestic","within the territory"],"legal_modality":["must","shall","required","may not unless"],"exact_phrases":["retain a copy in Singapore","stored within Singapore","maintain a local copy"]},"rule_filter":{"pass_when":["storage and domestic location both present"],"reject_when":["no location or infrastructure is primary obligation"],"review_when":["transfer permissibility unclear"]},"output_fields":["regulated_subject","data_category","territorial_nexus"]},
    {"indicator_id":"P6-I3","title":"Infrastructure requirements","task_type":"provision_classification","core_question":"Does a binding rule require domestic technical infrastructure?","source_scope":["binding current legal text"],"positive_conditions":["domestic server, data centre, network node or processing facility"],"required_signals":["infrastructure_signal","domestic_location","binding_obligation"],"exclusion_conditions":["segmentation","access control","cybersecurity policy","disaster recovery","backup policy","no geography","domestic copy only"],"confusable_with":["P6-I2"],"query_groups":{"objects":["server","data centre","network node","computing facility","processing facility"],"actions":["locate","operate","use","maintain"],"location_or_authority":["Singapore","within Singapore","domestic","locally"],"legal_modality":["must","shall","required"],"exact_phrases":["server located in Singapore","data centre within Singapore"]},"rule_filter":{"pass_when":["all required signals"],"reject_when":["storage-only obligation"],"review_when":["infrastructure and storage overlap; primary P6-I3, secondary P6-I2"]},"output_fields":["primary_indicator","secondary_signal"]},
    {"indicator_id":"P6-I4","title":"Conditional flow regimes","task_type":"provision_classification","core_question":"Is cross-border transfer legally possible when binding conditions are met?","source_scope":["binding current legal text"],"positive_conditions":["consent","adequacy","comparable protection","contractual safeguards","binding corporate rules","certification","approval","notification","risk assessment","statutory exception"],"required_signals":["cross_border_transfer","condition","transfer_remains_legally_possible"],"exclusion_conditions":["complete ban","domestic processing/storage/infrastructure","unrelated consent","confidentiality"],"confusable_with":["P6-I1","P6-I2","P6-I3"],"query_groups":{"objects":["personal data","data","overseas recipient"],"actions":["transfer","disclose","send"],"location_or_authority":["outside Singapore","overseas","foreign recipient","commissioner"],"legal_modality":["may","must","shall","unless"],"exact_phrases":["comparable standard of protection","legally enforceable obligations","transfer limitation obligation"]},"rule_filter":{"pass_when":["all required signals"],"reject_when":["transfer prohibited without ordinary path"],"review_when":["condition or transfer possibility unclear"]},"output_fields":["conditions","exceptions","ordinary_compliance_path_exists"]},
    {"indicator_id":"P6-I5","title":"Not participation in agreement with data transfer commitments","task_type":"external_status","core_question":"Does Singapore participate in an official agreement with binding data-transfer commitments?","source_scope":["official external source"],"positive_conditions":[],"required_signals":[],"exclusion_conditions":[],"confusable_with":[],"query_groups":{"objects":[],"actions":[],"location_or_authority":[],"legal_modality":[],"exact_phrases":[]},"rule_filter":{"pass_when":[],"reject_when":[],"review_when":[]},"output_fields":["agreement_name","participation_status","binding_commitment_present","effective_date","official_source","last_checked"],"search_sso_corpus":false,"requires_external_official_source":true},
