    {"indicator_id":"P7-I4","title":"DPIA or DPO requirements","task_type":"provision_classification","core_question":"Does a binding rule require DPO appointment or a DPIA?","source_scope":["binding current legal text"],"positive_conditions":["DPO_APPOINTMENT","DPIA_REQUIREMENT"],"required_signals":["binding obligation","personal-data focus"],"exclusion_conditions":["may appoint","should consider","voluntary","definition only","general risk assessment","unrelated cybersecurity assessment"],"confusable_with":["P7-I2"],"query_groups":{"objects":["data protection officer","impact assessment","personal data"],"actions":["appoint","designate","conduct","carry out"],"location_or_authority":["organisation","commissioner","controller"],"legal_modality":["must appoint","shall designate","required to appoint","must conduct","shall carry out"],"exact_phrases":["data protection officer","data protection impact assessment"]},"rule_filter":{"pass_when":["binding DPO or DPIA obligation"],"reject_when":["voluntary or unrelated assessment"],"review_when":["threshold or focus unclear"]},"output_fields":["obligation_type","covered_entity","threshold","trigger","timing","exemption","registration_requirement"]},
    {"indicator_id":"P7-I5","title":"Requirements to allow government access to personal data","task_type":"provision_classification","core_question":"Does public authority have binding access/disclosure power over personal or identifiable data?","source_scope":["binding current legal text"],"positive_conditions":["mandatory_disclosure","mandatory_production","lawful_interception","direct_system_access","inspection_or_copying","real_time_access","subscriber_information_request","traffic_or_location_data_access","decryption_or_assistance"],"required_signals":["government_or_public_authority","access_or_disclosure_power","personal_or_identifiable_data"],"exclusion_conditions":["internal sharing","anonymous statistics","non-personal business material","voluntary cooperation","ordinary regulatory information","unrelated civil evidence"],"confusable_with":["P7-I1"],"query_groups":{"objects":["personal data","subscriber information","traffic data","location data","identifiable information"],"actions":["produce","disclose","furnish","intercept","inspect","copy","decrypt"],"location_or_authority":["Minister","Commissioner","police","public authority","court"],"legal_modality":["must","shall","may require","warrant"],"exact_phrases":["produce any information","give access to","intercept communications"]},"rule_filter":{"pass_when":["all required signals"],"reject_when":["non-personal or voluntary information"],"review_when":["data identity or authority power unclear"]},"output_fields":["measure_subtype","warrant_required","court_authorisation","statutory_threshold","emergency_power","notice_to_data_subject","confidentiality","appeal_or_review"]}
